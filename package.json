{
  "name": "localbridge",
  "version": "0.1.0",
  "description": "Local development domain manager, HTTPS reverse proxy, and certificate manager",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "author": "LocalBridge",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "rebuild": "electron-builder install-app-deps",
    "package:win": "npm run build && electron-builder --win --x64",
    "package:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "download-binaries": "node scripts/download-binaries.mjs",
    "generate-icon": "node scripts/generate-icon.mjs"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "lucide-react": "^1.25.0",
    "png-to-ico": "^3.0.2",
    "prettier": "^3.9.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
